# --- Datenbank ---
MARIADB_ROOT_PASSWORD=Aendern_Root_Passwort_123!
MARIADB_DATABASE=suitecrm
MARIADB_USER=suitecrm_user
MARIADB_PASSWORD=Aendern_DB_Passwort_456!

